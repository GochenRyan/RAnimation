[submodule "Packages/assimp"]
	path = Packages/assimp
	url = https://github.com/assimp/assimp.git
	branch = master
[submodule "Packages/NRI"]
	path = Packages/NRI
	url = https://github.com/NVIDIA-RTX/NRI.git
	branch = main
[submodule "Packages/glm"]
	path = Packages/glm
	url = https://github.com/g-truc/glm.git
	branch = master
[submodule "Packages/Mathlib"]
	path = Packages/Mathlib
	url = https://github.com/NVIDIA-RTX/MathLib.git
	branch = main
[submodule "Packages/fmt"]
	path = Packages/fmt
	url = https://github.com/fmtlib/fmt.git
	branch = master
[submodule "Packages/detex"]
	path = Packages/detex
	url = https://github.com/GochenRyan/detex.git
	branch = master
[submodule "Packages/SDL"]
	path = Packages/SDL
	url = https://github.com/libsdl-org/SDL.git
	branch = main
